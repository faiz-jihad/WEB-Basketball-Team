# Supabase configuration for premium-hoops
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Administrative Role Passcodes (Removed for Security)
# Use Supabase Auth (Email & Password) instead.

# Firebase Cloud Messaging & App Config
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Web Push Certificate (VAPID Key) for Notifications
# Generate this in Firebase Console -> Project Settings -> Cloud Messaging -> Web Configuration
VITE_FIREBASE_VAPID_KEY=your_vapid_public_key
